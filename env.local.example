
# Adres publicznej strony (do linku "Zobacz na stronie" przy wydarzeniu w panelu)
NEXT_PUBLIC_SITE_URL=https://pisil.pl

# Wysyłka maili poza produkcją (dev). Domyślnie brama BLOKUJE wysyłkę na devie, żeby nie wysłać
# maila do prawdziwej osoby. Ustaw JEDNO z poniższych:
#   MAIL_CATCH_ALL=twoj@adres   -> wszystkie maile z deva trafiają na ten adres (zalecane — widzisz je)
#   ALLOW_REAL_SMTP=true        -> dev wysyła naprawdę (jak w produkcji)
# MAIL_CATCH_ALL=
# ALLOW_REAL_SMTP=false
