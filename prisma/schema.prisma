// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// NextAuth.js Models
model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verificationtokens")
}

// Status zgłoszenia
enum Status {
  PENDING
  APPROVED
  REJECTED
  ACCEPTED
}

// Typ formularza
enum FormType {
  DEKLARACJA_CZLONKOWSKA
  PATRONAT
  ANKIETA_SPEDYTOR_ROKU
  MLODY_SPEDYTOR_ROKU
}

// Typ członka (zwyczajny vs stowarzyszony) — wspólna numeracja, inne dokumenty/uprawnienia
enum MemberType {
  ZWYCZAJNY
  STOWARZYSZONY
}

// Model reprezentujący pojedyncze zgłoszenie formularza
model Submission {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status    Status   @default(PENDING)
  formType  FormType

  memberType MemberType @default(ZWYCZAJNY)

  createdByAdmin Boolean @default(false)
  isArchived     Boolean @default(false)
  
  companyName String   @default("Nieznana firma") 
  email       String   @default("brak@email.com")
  filePath  String   // ścieżka do podpisanego PDF
  fileName  String   // Oryginalna nazwa pliku

  invoiceEmail       String?  @default("")
  notificationEmails String?  @default("")

  attachments Attachment[]

  acceptanceNumber Int?     @unique

  ceoName String?
  address String?
  phones  String?
  fax     String?
  website String?
  nip     String?  // przechwycony z formularza deklaracji (mapowany do Member przy akceptacji)

  recommendations String?
  communicationNumber    Int?    @unique
  communicationFilePath  String?
  communicationFileName  String?

  member   Member? @relation(fields: [memberId], references: [id], onDelete: SetNull)
  memberId String?
}

enum AttachmentSource {
  CLIENT_UPLOAD // Pliki od klienta LUB dodane ręcznie przez admina (traktujemy je tak samo)
  GENERATED     // Pliki wygenerowane przez system (np. dokumenty przyjęcia)
}

model Attachment {
  id           String     @id @default(cuid())
  createdAt    DateTime   @default(now())
  fileName     String
  filePath     String    
  submission   Submission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  submissionId String

  source       AttachmentSource @default(CLIENT_UPLOAD)
}

model Member {
  id        String   @id @default(cuid())
  email     String   @unique 
  password  String   
  name      String?  
  company   String? 
  address   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  memberNumber Int?     @unique
  phones       String?

  invoiceEmail       String?
  notificationEmails String?

  passwordResetToken   String?   @unique 
  passwordResetExpires DateTime?
  mustChangePassword Boolean @default(false)

  fax     String?
  website String?

  // Typ członka (zwyczajny domyślnie / stowarzyszony)
  memberType MemberType @default(ZWYCZAJNY)

  // Dane wewnętrzne (NIE na liście publicznej): faktury / korespondencja / e-doręczenia
  nip                   String?
  correspondenceAddress String?  // adres do korespondencji (pusty = jak rejestrowy `address`)
  eDeliveryConsent      Boolean  @default(false) // zgoda na wysyłkę elektroniczną
  eDeliveryEmail        String?  // e-mail do e-wysyłki (pusty = główny `email`)
  eDeliveryAddress      String?  // adres e-doręczeń (ADE)

  // Miękkie usuwanie (byli członkowie) — gdy deletedAt != null, konto jest "byłym członkiem"
  deletedAt   DateTime?
  removalNote String?

  submissions Submission[]
  files       MemberFile[]
}

model MemberFile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  
  fileName  String   // Nazwa pliku widoczna dla użytkownika
  filePath  String   // Ścieżka do pliku w GCS

  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  memberId  String
}

model GeneralFile {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  
  fileName  String   
  filePath  String   
  
  category String? 
}

enum CommunicationStatus {
  DRAFT
  SENT
}

model Communication {
  id        String   @id @default(cuid())
  title     String
  year      Int
  fileName  String?  // nullable — legacy rekordy mają wypełnione, nowe mogą nie mieć pliku głównego
  filePath  String?  // nullable

  // Pola strukturalne (null = rekordy archiwalne / legacy)
  number         Int?               // sekwencja w miesiącu (1, 2, 3…)
  month          Int?               // 1–12
  sentAt         DateTime?
  authorInitials String?
  authorName     String?            // pełne imię i nazwisko (do stopki dokumentu)
  authorPosition String?            // stanowisko (np. "Specjalistka ds. celnych")
  authorLabel    String?            // etykieta (np. "Przygotowała:" / "Przygotował:")
  subject        String?            // "sprawa" — temat do spisu i subject maila
  body           String?            @db.Text
  attachmentNames String?           // tekstowa lista nazw załączników (do spisu)
  status         CommunicationStatus @default(DRAFT)
  isSpis         Boolean            @default(false)

  attachments CommunicationAttachment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CommunicationAttachment {
  id              String        @id @default(cuid())
  communicationId String
  communication   Communication @relation(fields: [communicationId], references: [id], onDelete: Cascade)
  fileName        String
  filePath        String
  createdAt       DateTime      @default(now())
}

// Zarządzana lista inicjałów autorów komunikatów (osobna od authorInitials w Communication)
model CommunicationAuthor {
  initials  String   @id
  name      String?
  position  String?
  label     String?
  createdAt DateTime @default(now())
}

// =====================================================================
// Wydarzenia (szkolenia / konferencje) — rejestracje online
// =====================================================================

enum EventType {
  SZKOLENIE
  KONFERENCJA
}

enum EventMode {
  ONLINE
  STACJONARNE
}

enum EventStatus {
  DRAFT       // szkic — niewidoczny publicznie
  PUBLISHED   // opublikowane — widoczne, rejestracja otwarta (wg deadline/limitu)
  CLOSED      // rejestracja zamknięta ręcznie
  ARCHIVED    // zarchiwizowane
}

// Poziom cenowy zgłoszenia (liczony serwerowo, z możliwością nadpisania przez admina)
enum RegistrationTier {
  CZLONEK_GRATIS   // członek w ramach puli darmowej (konferencja)
  CZLONEK_PLATNY   // członek płatny (cena członka)
  NIECZLONEK       // nie-członek (cena nie-członka)
}

enum PaymentStatus {
  ZWOLNIONY   // gratis — brak płatności
  OCZEKUJE    // oczekuje na przelew
  OPLACONE    // opłacone
}

enum RegistrationStatus {
  POTWIERDZONA
  LISTA_REZERWOWA
  ANULOWANA
}

enum RegSource {
  SELF    // zapis własny przez stronę
  ADMIN   // dopisany ręcznie przez admina
}

model Event {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug        String    @unique // do URL-i (strona podglądu / WordPress)
  typ         EventType
  tryb        EventMode
  title       String
  description String?   @db.Text // krótki opis (marketing i tak w WP)

  startAt             DateTime
  endAt               DateTime?
  prowadzacy          String?
  address             String?   // adres (dla STACJONARNE) — pod mapkę
  onlineUrl           String?   // link (dla ONLINE)
  limitMiejsc         Int?
  registrationDeadline DateTime?
  bankAccount         String?   // nr konta do przelewu (pusty = domyślny z konfiguracji)

  // Model cenowy 2-poziomowy
  cenaCzlonek       Decimal? @db.Decimal(10, 2)
  cenaNieczlonek    Decimal? @db.Decimal(10, 2)
  pulaGratisNaFirme Int      @default(0) // konferencja=2, szkolenie=0

  seriesName String?     // opcjonalne grupowanie "cyklu"
  status     EventStatus @default(DRAFT)

  registrations EventRegistration[]
}

model EventRegistration {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  event   Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  eventId String

  firstName  String
  lastName   String
  email      String
  firmaNazwa String
  firmaNip   String
  firmaAdres String? // adres do faktury

  tier            RegistrationTier
  kwota           Decimal            @db.Decimal(10, 2)
  statusPlatnosci PaymentStatus
  statusRejestracji RegistrationStatus @default(POTWIERDZONA)

  zgodaRodo   Boolean
  zgodaRodoAt DateTime?
  zrodlo      RegSource @default(SELF)

  matchedMemberId String? // członek dopasowany po NIP (referencyjnie; bez FK)
  notatka         String?

  @@index([eventId])
  @@index([eventId, firmaNip])
}